// 3959. Check Good Integer

class Solution {
    public boolean checkGoodInteger(int n) {
        int ds =0;
        int ss =0;
        int a = n;
        while(a!=0){
            int c = a%10;
            ds+=c;
            ss+=c*c;
            a/=10;
        }
        return ss - ds >= 50;
    }
}