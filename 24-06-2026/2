// Strange's cyclic number

// You are using Java
import java.util.*;
class Main{
    public static void main(String[] args){
        Scanner sc = new Scanner(System.in);
        String str = sc.next();
        String str2 = sc.next();
        String str1 = str2 + str2;
        if(str1.contains(str)){
            System.out.print("Yes");
        }else{
            System.out.print("No");
        }
    }
}