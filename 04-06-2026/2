// 189. Rotate Array

class Solution {
    public void rotate(int[] nums, int k) {
        int [] arr = new int[nums.length];

        int j = k%nums.length;
        for(int i = 0;i<nums.length;i++){
            arr[j]=nums[i];
            j++;
            if(j==nums.length){
                j=0;
            }
        }
        for(int i =0;i<nums.length;i++){
            nums[i]=arr[i];
        }
    }
}