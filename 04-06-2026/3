// 122. Best Time to Buy and Sell Stock II

class Solution {
    public int maxProfit(int[] prices) {
        int profit=0;
        int buy = prices[0];
        for(int i = 1;i<prices.length;i++){
            int sell = prices[i]-buy;
            if(sell>0){
                profit+=sell;
            }
            buy=prices[i];
        }
        return profit;
        
    }
}