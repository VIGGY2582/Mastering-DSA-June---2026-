// 55. Jump Game

class Solution {
    public boolean canJump(int[] nums) {
        if(nums.length==1){
            return true;
        }
        int desti = nums.length-1;
        for(int i =nums.length-2;i>-1;i--){
            if(desti-i <= nums[i]){
                desti = i;
            }
        }
        if(desti == 0){
            return true;
        }
        return false;
    }
}